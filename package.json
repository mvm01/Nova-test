{
  "name": "nova-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:win": "npm run build && electron-builder --win",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.fiddler-killer.app",
    "productName": "Fiddler-Killer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/http-mitm-proxy/**/*",
      "**/*.node"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@tanstack/react-virtual": "^3.14.3",
    "clsx": "^2.1.1",
    "http-mitm-proxy": "^1.1.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
